{
  "name": "myui",
  "version": "0.2.0",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./with-styles": {
      "types": "./dist/with-styles.d.ts",
      "import": "./dist/with-styles.js"
    },
    "./styles.css": "./dist/myui.css",
    "./Button": {
      "types": "./dist/components/Button/index.d.ts",
      "import": "./dist/components/Button/index.js"
    },
    "./Calendar": {
      "types": "./dist/components/Calendar/index.d.ts",
      "import": "./dist/components/Calendar/index.js"
    },
    "./Checkbox": {
      "types": "./dist/components/Checkbox/index.d.ts",
      "import": "./dist/components/Checkbox/index.js"
    },
    "./ColorPicker": {
      "types": "./dist/components/ColorPicker/index.d.ts",
      "import": "./dist/components/ColorPicker/index.js"
    },
    "./ComboBox": {
      "types": "./dist/components/ComboBox/index.d.ts",
      "import": "./dist/components/ComboBox/index.js"
    },
    "./DateField": {
      "types": "./dist/components/DateField/index.d.ts",
      "import": "./dist/components/DateField/index.js"
    },
    "./Popover": {
      "types": "./dist/components/Popover/index.d.ts",
      "import": "./dist/components/Popover/index.js"
    },
    "./RadioGroup": {
      "types": "./dist/components/RadioGroup/index.d.ts",
      "import": "./dist/components/RadioGroup/index.js"
    },
    "./Slider": {
      "types": "./dist/components/Slider/index.d.ts",
      "import": "./dist/components/Slider/index.js"
    },
    "./Switch": {
      "types": "./dist/components/Switch/index.d.ts",
      "import": "./dist/components/Switch/index.js"
    },
    "./Tabs": {
      "types": "./dist/components/Tabs/index.d.ts",
      "import": "./dist/components/Tabs/index.js"
    },
    "./TextArea": {
      "types": "./dist/components/TextArea/index.d.ts",
      "import": "./dist/components/TextArea/index.js"
    },
    "./TextField": {
      "types": "./dist/components/TextField/index.d.ts",
      "import": "./dist/components/TextField/index.js"
    },
    "./ToggleButtonGroup": {
      "types": "./dist/components/ToggleButtonGroup/index.d.ts",
      "import": "./dist/components/ToggleButtonGroup/index.js"
    },
    "./Tooltip": {
      "types": "./dist/components/Tooltip/index.d.ts",
      "import": "./dist/components/Tooltip/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && npm run copy-css",
    "copy-css": "find src/components -name '*.module.css' -exec sh -c 'mkdir -p dist/$(dirname ${1#src/}) && cp \"$1\" dist/${1#src/}' _ {} \\; && cp src/myui.css dist/myui.css",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "dev": "tsc -w",
    "clean": "rm -rf dist",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "dependencies": {
    "culori": "^4.0.2",
    "luxon": "^3.7.2",
    "react-aria-components": "^1.15.1"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.2.8",
    "@storybook/react-vite": "^10.2.8",
    "@stylistic/eslint-plugin": "^5.8.0",
    "@types/culori": "^4.0.1",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.2.2",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-storybook": "^10.2.8",
    "globals": "^17.3.0",
    "sanitize.css": "^13.0.0",
    "storybook": "^10.2.8",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0"
  }
}
